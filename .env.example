# CEMS Environment Variables
# Copy this file to .env and fill in your values

# Required - Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Required - Generate a secure admin key with: openssl rand -hex 32
CEMS_ADMIN_KEY=your-admin-key-here

# Optional - PostgreSQL password (default: cems_secure_password)
# Change this in production!
POSTGRES_PASSWORD=cems_secure_password
