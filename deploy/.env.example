# CEMS Server Configuration
# Copy to .env and fill in your values

# ==============================================================================
# Required Settings
# ==============================================================================

# PostgreSQL password (for metadata and user management)
POSTGRES_PASSWORD=change_me_to_secure_password

# OpenRouter API key (for LLM + embeddings)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Admin API key (for /admin/* endpoints to create users)
CEMS_ADMIN_KEY=cems_admin_change_me_to_secure_key

# ==============================================================================
# Optional Model Configuration
# ==============================================================================

# Embedding model
# CEMS_EMBEDDING_MODEL=openai/text-embedding-3-small

# Model for maintenance operations
# CEMS_LLM_MODEL=anthropic/claude-3-haiku

# ==============================================================================
# Optional Graph Store Settings
# ==============================================================================

# Enable knowledge graph for relationship tracking
# CEMS_ENABLE_GRAPH=true

# Graph backend: "kuzu" (embedded) or "none" (disabled)
# CEMS_GRAPH_STORE=kuzu

# ==============================================================================
# Optional Scheduler Settings
# ==============================================================================

# Nightly consolidation: merge duplicates, promote hot memories
# CEMS_NIGHTLY_HOUR=3

# Weekly summarization: compress old memories, prune stale ones
# CEMS_WEEKLY_DAY=sun
# CEMS_WEEKLY_HOUR=4

# Monthly re-indexing: rebuild embeddings, archive dead memories
# CEMS_MONTHLY_DAY=1
# CEMS_MONTHLY_HOUR=5

# ==============================================================================
# Optional Decay Settings
# ==============================================================================

# Days before a memory is considered "stale" (eligible for pruning)
# CEMS_STALE_DAYS=90

# Days before a memory is archived (removed from active search)
# CEMS_ARCHIVE_DAYS=180

# Access count threshold to consider a memory "hot" (promoted)
# CEMS_HOT_ACCESS_THRESHOLD=5

# Cosine similarity threshold for duplicate detection
# CEMS_DUPLICATE_SIMILARITY_THRESHOLD=0.92

# ==============================================================================
# Optional Server Settings
# ==============================================================================

# CEMS_SERVER_HOST=0.0.0.0
# CEMS_SERVER_PORT=8765

# ==============================================================================
# Optional Storage Settings (for local development)
# ==============================================================================

# Base storage directory (default: ~/.cems)
# CEMS_STORAGE_DIR=/path/to/storage
